# ============================================================
# Copier ce fichier en .env et remplir les vraies valeurs.
# Ne jamais committer .env dans git.
# ============================================================

# IP publique du VPS
VPS_IP=1.2.3.4

# PostgreSQL
DB_PASSWORD=changeme_db_password

# JWT (minimum 32 caractères)
JWT_SECRET=changeme_jwt_secret_must_be_at_least_32_chars

# Compte administrateur
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme_admin_password

# Gmail SMTP (pour le formulaire de contact)
# 1. Activer la validation en 2 étapes sur byaurardtw@gmail.com
# 2. Créer un "Mot de passe d'application" sur myaccount.google.com/apppasswords
# 3. Coller ce mot de passe (16 caractères) ici — PAS le mot de passe Gmail normal
MAIL_USERNAME=byaurardtw@gmail.com
MAIL_PASSWORD=changeme_app_password_16_chars
