byaura.duckdns.org {
    handle /api/* {
        reverse_proxy backend:4000
    }
    handle /uploads/* {
        reverse_proxy backend:4000
    }
    handle {
        reverse_proxy frontend:80
    }
}

byaura-admin.duckdns.org {
    handle /api/* {
        reverse_proxy backend:4000
    }
    handle /uploads/* {
        reverse_proxy backend:4000
    }
    handle {
        reverse_proxy admin:80
    }
}